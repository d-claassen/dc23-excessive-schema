{
    "name": "dennis/dc23-excessive-schema",
    "description": "Template-level schema enrichment for WordPress Query Loop blocks",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "files": [
            "lib/functions.php"
        ],
        "psr-4": {
            "DC23\\ExcessiveSchema\\": "lib/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "wpackagist-plugin/wordpress-seo": ">=24.0,<=27.6",
        "yoast/yoastcs": "^3.1",
        "composer/installers": "^2.0",
        "phpunit/phpunit": "^11.5",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "vendor-dir": "vendor",
        "preferred-install": "dist"
    },
    "extra": {
        "installer-paths": {
            "vendor/wpackagist/{$name}/": [
                "type:wordpress-plugin"
            ]
        }
    },
    "scripts": {
        "phplint": "@php ./vendor/bin/parallel-lint . -e php --show-deprecated --exclude vendor --exclude .git",
        "phpcs": "@php ./vendor/bin/phpcs --runtime-set ignore_warnings_on_exit 1",
        "test": "@php ./vendor/bin/phpunit --process-isolation"
    }
}
